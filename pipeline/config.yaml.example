# GeoAgentBench Pipeline v3 配置文件
# 复制为 config.yaml 并填入真实 API Key

# Google Maps API 配置
google_maps:
  api_key: "YOUR_GOOGLE_MAPS_API_KEY"

# 阿里通义千问 DashScope API 配置
dashscope:
  api_key: "YOUR_DASHSCOPE_API_KEY"
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"

# 模型选择（集中管理，方便后续切换为自部署模型）
models:
  # 视觉模型（图像解析）
  vision: "qwen-vl-max"
  # 文本生成模型（结构化数据生成、质控审核、反向校验）
  text: "qwen-plus"
  # 文本生成模型（自然语言转写，需要更强语言能力）
  text_strong: "qwen-max"
